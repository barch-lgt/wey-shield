# Wey Shield — Environment Variables
# Copy to .env for local dev. Set these as Render environment variables in production.

# Groq (required for AI interpretation)
GROQ_API_KEY=your_groq_api_key_here

# Supabase (required for storage + training archive)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Security
SHIELD_SCOPE_SALT=replace_with_random_64_char_string
INTERNAL_API_KEY=replace_with_random_string_for_internal_endpoints
